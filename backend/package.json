{
  "name": "elektrikciler-backend",
  "version": "1.3.0",
  "description": "Elektrikçiler Platform Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/kill-port.js && nodemon",
    "build": "node scripts/clean-dist.js && prisma generate && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "audit:source-data": "node scripts/audit-source-data.js",
    "audit:target-data": "node scripts/audit-target-data.js",
    "audit:source-media": "node scripts/audit-source-media.js",
    "audit:target-media": "node scripts/audit-target-media.js",
    "migrate:supabase:plan": "node scripts/migrate-supabase-project.js",
    "migrate:supabase:execute": "node scripts/migrate-supabase-project.js --execute",
    "smtp:plan": "node scripts/configure-production-smtp.js",
    "smtp:configure": "node scripts/configure-production-smtp.js --execute",
    "test:supabase:rls": "node scripts/test-supabase-rls.js",
    "test:supabase:storage": "node scripts/test-supabase-storage.js",
    "test:supabase:core": "node scripts/test-supabase-core-workflows.js",
    "test:supabase:realtime": "node scripts/test-supabase-realtime.js",
    "test:supabase:edge": "node scripts/test-supabase-edge-functions.js",
    "test:supabase:push-cron": "node scripts/test-supabase-push-cron.js",
    "test:supabase": "npm run test:supabase:rls && npm run test:supabase:storage && npm run test:supabase:core && npm run test:supabase:realtime && npm run test:supabase:edge && npm run test:supabase:push-cron",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck",
    "seed": "ts-node scripts/seedTestData.ts",
    "test": "npm run verify"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "morgan": "^1.10.1",
    "prisma": "^6.2.1",
    "redis": "^5.10.0",
    "socket.io": "^4.8.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2"
  }
}
