{
  "expo": {
    "name": "işbitir",
    "slug": "elektrikciler",
    "version": "1.6.16",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#071321"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mpakdil.isbitir",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Arıza fotoğrafları çekebilmeniz için kameraya erişim izni gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotoğraf seçebilmeniz için kütüphaneye erişim izni gerekiyor.",
        "NSLocationWhenInUseUsageDescription": "Size en yakın iş ilanlarını ve ustaları göstermek için konum izni gerekiyor.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 166,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#071321"
      },
      "package": "com.mpakdil.isbitir",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "./plugins/withModularHeaders",
      "./plugins/withAndroidDialerQuery",
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#6200EE",
          "sounds": [],
          "icon": "./assets/images/icon.png",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-iap",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "isbitir",
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f894540e-3b89-4157-a0e0-5ed3bfd1ad72"
      }
    },
    "owner": "incesu01"
  }
}
